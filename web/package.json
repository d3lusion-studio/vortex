{
  "name": "vortex-web",
  "version": "0.1.0",
  "private": true,
  "description": "Web ecosystem for the Vortex game engine (marketing site, docs, playground, registry).",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @vortex/site dev",
    "build": "pnpm --filter @vortex/site build",
    "start": "pnpm --filter @vortex/site start",
    "typecheck": "pnpm -r --parallel typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,mdx,json,css}\""
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  }
}
